
{
  "version": 2,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS, DELETE" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-admin-key" }
      ]
    }
  ]
}
  
   

